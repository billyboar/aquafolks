# Server
PORT=3000
ENVIRONMENT=development

# Database (will be replaced with Supabase URL later)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aquabook?sslmode=disable

# Redis
REDIS_URL=localhost:6379

# JWT
JWT_SECRET=your-secret-key-change-in-production

# Storage (MinIO for local development)
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=aquabook

# OAuth (add your credentials when ready)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_SECRET=
